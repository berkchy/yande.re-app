{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/posts.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/posts", "dest": "/api/posts.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}