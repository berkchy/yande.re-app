{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/posts.js", "use": "@vercel/node" },
    { "src": "api/view.js", "use": "@vercel/node" },
    { "src": "api/nocache.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/posts", "dest": "/api/posts.js" },
    { "src": "/api/view", "dest": "/api/view.js" },

    { "src": "/", "dest": "/api/nocache.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}